{
  "name": "ts-bedrock",
  "author": "huy",
  "version": "1.0.0",
  "license": "ISC",
  "description": "Monorepo for TypeFirst Bedrock Typescript project",
  "scripts": {
    "start": "bash ./devops/dev/start.sh",
    "tsc": "tsc --noEmit",
    "lint": "esw ./ --ext .ts --ext .tsx --max-warnings=0",
    "external:start": "bash ./devops/external/start.sh",
    "db:migrate": "bash ./devops/external/db-migrate.sh",
    "db:seed": "bash ./devops/external/db-seed.sh",
    "db:rollback": "bash ./devops/external/db-rollback.sh",
    "db:migrate:create": "bash ./devops/external/db-migrate-create.sh",
    "ai:ingest": "bash ./devops/dev/ai-ingest.sh",
    "ai:ingest:reset": "bash ./devops/dev/ai-ingest-reset.sh",
    "ai:ingest:faq": "bash ./devops/dev/ai-ingest-faq.sh",
    "test": "bash ./devops/test/run-test.sh",
    "test:watch": "bash ./devops/test/run-test.sh --watch",
    "deploy:staging": "docker compose -f ./devops/deploy/docker-compose.staging.yml up -d --build --remove-orphans",
    "deploy:staging:down": "docker compose -f ./devops/deploy/docker-compose.staging.yml down",
    "deploy:production": "docker compose -f ./devops/deploy/docker-compose.production.yml up -d --build --remove-orphans",
    "deploy:production:down": "docker compose -f ./devops/deploy/docker-compose.production.yml down",
    "staging:deploy:api": "npm run deploy:staging",
    "staging:deploy:web": "npm run deploy:staging",
    "production:deploy:api": "npm run deploy:production",
    "production:deploy:web": "npm run deploy:production"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "date-fns": "^4.1.0",
    "decoders": "^2.7.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "pino-http": "^11.0.0",
    "pino-http-print": "^4.0.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-quill-new": "^3.8.3",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.1.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "baseline-browser-mapping": "^2.9.14",
    "concurrently": "^9.2.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jam3": "^0.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-watch": "^8.0.0",
    "kysely": "^0.28.9",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "contributes": {
    "snippets": [
      {
        "language": [
          "markdown"
        ],
        "path": "./.ai/snippets/prompts.json"
      }
    ]
  }
}
