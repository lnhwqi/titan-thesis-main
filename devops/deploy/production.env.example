# Browser-facing API host, without protocol.
# Example: api.example.com
VITE_API_HOST=api.example.com

# Published ports on EC2 host (production)
WEB_PORT_PUBLISHED=80
API_PORT_PUBLISHED=3001
DB_PORT_PUBLISHED=5432

# Production DB credentials (must be different from staging)
DB_USER=admin_production
DB_PASSWORD=change_me_production
DB_DATABASE=production
DB_MAX_POOL=30

# Production API secrets (must be different from staging)
JWT_SECRET=change_me_with_long_random_string
ZALO_APP_ID=production_app_id
ZALO_KEY1=production_key1
ZALO_KEY2=production_key2
ZALO_CREATE_URL=https://api.zalo.example/create
ZALO_QUERY_URL=https://api.zalo.example/query
GHN_TOKEN=production_ghn_token
GHN_URL=https://online-gateway.ghn.vn
