# Browser-facing API host, without protocol.
# Example: staging-api.example.com or 54.123.45.67:3002
VITE_API_HOST=staging-api.example.com

# Published ports on EC2 host (staging)
WEB_PORT_PUBLISHED=8080
API_PORT_PUBLISHED=3002
DB_PORT_PUBLISHED=55432

# Staging DB credentials (must be different from production)
DB_USER=admin_staging
DB_PASSWORD=change_me_staging
DB_DATABASE=titan_staging
DB_MAX_POOL=20

# Staging API secrets (must be different from production)
JWT_SECRET=change_me_with_long_random_string
ZALO_APP_ID=staging_app_id
ZALO_KEY1=staging_key1
ZALO_KEY2=staging_key2
ZALO_CREATE_URL=https://sandbox.zalo.example/create
ZALO_QUERY_URL=https://sandbox.zalo.example/query
GHN_TOKEN=staging_ghn_token
GHN_URL=https://staging-online-gateway.ghn.vn
